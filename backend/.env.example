# ══════════════════════════════════════════════
# ENFOQUE 365 — Configuracion de entorno
# ══════════════════════════════════════════════

# Base de datos
DATABASE_URL=postgresql://enfoque_user:enfoque_password@localhost:5434/enfoque365

# ── LLM Providers ────────────────────────────
# Configura al menos UNA API key para activar IA real.
# Si no hay keys, el sistema usa fallback deterministico.
# Prioridad por defecto: gemini → openai → anthropic

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# OpenAI ChatGPT (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Anthropic Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Provider preferido: gemini | openai | anthropic
LLM_DEFAULT_PROVIDER=gemini
